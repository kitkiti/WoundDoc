# Use `demo` for the built-in deterministic fallback, or `script` for an external adapter.
WOUNDDOC_MODEL_PROVIDER=demo

# Keep true for a guaranteed demo-safe setup.
WOUNDDOC_FORCE_DEMO=true

# Optional friendly model name shown in the UI and response metadata.
WOUNDDOC_MODEL_NAME=

# Set when WOUNDDOC_MODEL_PROVIDER=script.
WOUNDDOC_MODEL_SCRIPT=
WOUNDDOC_EXTERNAL_PYTHON=python3
WOUNDDOC_MODEL_TIMEOUT_MS=6000
WOUNDDOC_LOG_LEVEL=debug
